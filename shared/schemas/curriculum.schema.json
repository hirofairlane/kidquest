{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kidquest.local/schemas/curriculum.schema.json",
  "title": "Curriculum",
  "description": "Data-driven pedagogy binding a profile to subjects and concepts. Adding a profile is adding one of these.",
  "type": "object",
  "additionalProperties": false,
  "required": ["curriculum_ref", "subjects"],
  "properties": {
    "curriculum_ref": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
    "title": { "type": "string" },
    "subjects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["subject", "language", "concepts"],
        "properties": {
          "subject": {
            "type": "string",
            "enum": ["math", "spanish", "science", "history", "geography", "english", "electronics"]
          },
          "language": {
            "type": "string",
            "enum": ["es", "en"],
            "description": "Language puzzles for this subject must be presented in."
          },
          "weight": {
            "type": "number",
            "description": "Relative emphasis when generating the daily level.",
            "minimum": 0,
            "default": 1
          },
          "concepts": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["concept_id", "label", "difficulty"],
              "properties": {
                "concept_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
                "label": { "type": "string" },
                "difficulty": { "type": "integer", "minimum": 1, "maximum": 5 }
              }
            }
          }
        }
      }
    }
  }
}
