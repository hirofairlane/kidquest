# KidQuest content/API server (FastAPI + uvicorn). CPU-only; no inference here.
FROM python:3.12-slim

WORKDIR /app
COPY server /app/server
RUN pip install --no-cache-dir ./server "uvicorn[standard]>=0.30"

ENV KIDQUEST_CONTENT_STORE=/content-store \
    KIDQUEST_DATA=/data
EXPOSE 8000

CMD ["uvicorn", "kidquest_server.app:app", "--host", "0.0.0.0", "--port", "8000"]
