{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kidquest.local/schemas/challenge_set.schema.json",
  "title": "ChallengeSet",
  "description": "The educational layer the AI authors for one day's map and learner: curriculum-tagged Sphinx riddles, signs and events to be patched into a fheroes2 .fh2m template. The strict contract for the local LLM (Ollama structured output) and validated server-side.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "profile_id", "era", "language_default", "sphinxes"],
  "properties": {
    "schema_version": { "type": "string", "const": "1" },
    "profile_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
    "era": {
      "type": "string",
      "description": "Historical era / civilization theme of the map.",
      "enum": ["greek_colonies", "phoenician_carthaginian", "roman_hispania", "visigothic", "al_andalus", "christian_kingdoms"]
    },
    "language_default": { "$ref": "#/$defs/language" },
    "sphinxes": {
      "type": "array",
      "minItems": 1,
      "description": "Riddle challenges, one per Sphinx slot in the template.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["subject", "concept_tags", "riddle", "answers", "reward"],
        "properties": {
          "subject": { "$ref": "#/$defs/subject" },
          "concept_tags": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "riddle": { "$ref": "#/$defs/localizedText" },
          "answers": {
            "type": "array",
            "minItems": 1,
            "description": "All accepted answer strings. fheroes2 matches EXACTLY, so enumerate tolerant variants (case, accents, synonyms, es/en).",
            "items": { "type": "string", "minLength": 1 }
          },
          "hint": { "anyOf": [{ "$ref": "#/$defs/localizedText" }, { "type": "null" }] },
          "reward": { "$ref": "#/$defs/reward" }
        }
      }
    },
    "signs": {
      "type": "array",
      "description": "Lore / hint text placed on signs.",
      "items": { "$ref": "#/$defs/localizedText" }
    },
    "events": {
      "type": "array",
      "description": "Adventure-map events: a message plus a reward.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["message", "reward"],
        "properties": {
          "message": { "$ref": "#/$defs/localizedText" },
          "reward": { "$ref": "#/$defs/reward" }
        }
      }
    }
  },
  "$defs": {
    "language": { "type": "string", "enum": ["es", "en"] },
    "subject": {
      "type": "string",
      "enum": ["math", "spanish", "science", "history", "geography", "english", "electronics"]
    },
    "localizedText": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "language"],
      "properties": {
        "text": { "type": "string", "minLength": 1 },
        "language": { "$ref": "#/$defs/language" }
      }
    },
    "reward": {
      "type": "object",
      "additionalProperties": false,
      "description": "Resource reward granted on success (fheroes2 Funds).",
      "properties": {
        "gold": { "type": "integer", "minimum": 0, "default": 0 },
        "wood": { "type": "integer", "minimum": 0, "default": 0 },
        "ore": { "type": "integer", "minimum": 0, "default": 0 },
        "mercury": { "type": "integer", "minimum": 0, "default": 0 },
        "sulfur": { "type": "integer", "minimum": 0, "default": 0 },
        "crystal": { "type": "integer", "minimum": 0, "default": 0 },
        "gems": { "type": "integer", "minimum": 0, "default": 0 }
      }
    }
  }
}
