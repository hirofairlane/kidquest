# Build the Phaser client and serve it via nginx, proxying API paths to the api service.
FROM node:22-alpine AS build
WORKDIR /app
RUN corepack enable
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY client ./client
COPY shared ./shared
RUN pnpm install --frozen-lockfile=false && pnpm -C client build

FROM nginx:alpine
COPY deploy/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/client/dist /usr/share/nginx/html
EXPOSE 80
