{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kidquest.local/schemas/daily_level.schema.json",
  "title": "DailyLevel",
  "description": "The strict contract the local LLM must return for one day's level. Cross-field invariants (matrix dims, ref resolution, axial-in-radius, >=1 player unit) are enforced by schema_validator.py and the client LevelLoader.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "profile_id", "language_default", "overworld", "entities", "puzzles", "dialogues", "encounters"],
  "properties": {
    "schema_version": { "type": "string", "const": "1" },
    "profile_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
    "language_default": { "$ref": "#/$defs/language" },
    "overworld": {
      "type": "object",
      "additionalProperties": false,
      "required": ["width", "height", "tile_legend", "matrix", "start"],
      "properties": {
        "width": { "type": "integer", "minimum": 1, "maximum": 64 },
        "height": { "type": "integer", "minimum": 1, "maximum": 64 },
        "tile_legend": {
          "type": "object",
          "description": "Map from stringified integer tile id to its definition.",
          "minProperties": 1,
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "walkable", "kind"],
            "properties": {
              "name": { "type": "string" },
              "walkable": { "type": "boolean" },
              "kind": { "type": "string", "enum": ["grass", "water", "mountain", "wall", "road", "forest", "sand"] }
            }
          }
        },
        "matrix": {
          "type": "array",
          "description": "height rows of width tile ids; ids must exist in tile_legend.",
          "items": { "type": "array", "items": { "type": "integer", "minimum": 0 } }
        },
        "start": { "$ref": "#/$defs/gridPos" }
      }
    },
    "entities": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "type", "pos"],
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string", "enum": ["chest", "npc", "monster"] },
          "pos": { "$ref": "#/$defs/gridPos" },
          "puzzle_ref": { "type": ["string", "null"] },
          "dialogue_ref": { "type": ["string", "null"] },
          "encounter_ref": { "type": ["string", "null"] },
          "lore": { "type": ["string", "null"], "description": "Lore tag, e.g. 'gamusino', 'cuelebre', 'artificer_device'." }
        }
      }
    },
    "puzzles": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "concept_tags", "subject", "prompt", "kind", "answer"],
        "properties": {
          "id": { "type": "string" },
          "concept_tags": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "subject": { "$ref": "#/$defs/subject" },
          "prompt": { "$ref": "#/$defs/localizedText" },
          "kind": {
            "type": "string",
            "enum": ["multiple_choice", "free_text", "i_spy_shape", "name_in_english", "circuit"]
          },
          "options": { "type": ["array", "null"], "items": { "type": "string" } },
          "answer": { "type": "string", "description": "Canonical answer." },
          "accepted_answers": {
            "type": ["array", "null"],
            "items": { "type": "string" },
            "description": "Additional accepted forms (normalized client-side)."
          },
          "hint": { "anyOf": [{ "$ref": "#/$defs/localizedText" }, { "type": "null" }] }
        }
      }
    },
    "dialogues": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "speaker", "lines"],
        "properties": {
          "id": { "type": "string" },
          "speaker": { "type": "string" },
          "lines": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["text", "language", "voice"],
              "properties": {
                "text": { "type": "string" },
                "language": { "$ref": "#/$defs/language" },
                "voice": { "type": "string", "description": "Piper voice id mapped server-side." }
              }
            }
          }
        }
      }
    },
    "encounters": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "hex_radius", "units"],
        "properties": {
          "id": { "type": "string" },
          "hex_radius": { "type": "integer", "minimum": 1, "maximum": 8 },
          "units": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "team", "name", "axial", "initiative", "stats"],
              "properties": {
                "id": { "type": "string" },
                "team": { "type": "string", "enum": ["player", "enemy"] },
                "name": { "type": "string" },
                "axial": { "$ref": "#/$defs/axialCoord" },
                "initiative": { "type": "integer", "minimum": 0 },
                "stats": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["hp", "atk", "def", "speed", "range"],
                  "properties": {
                    "hp": { "type": "integer", "minimum": 1 },
                    "atk": { "type": "integer", "minimum": 0 },
                    "def": { "type": "integer", "minimum": 0 },
                    "speed": { "type": "integer", "minimum": 0 },
                    "range": { "type": "integer", "minimum": 1 }
                  }
                },
                "lore": { "type": ["string", "null"] }
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "language": { "type": "string", "enum": ["es", "en"] },
    "subject": {
      "type": "string",
      "enum": ["math", "spanish", "science_en", "history", "geography", "english", "electronics"]
    },
    "gridPos": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y"],
      "properties": {
        "x": { "type": "integer", "minimum": 0 },
        "y": { "type": "integer", "minimum": 0 }
      }
    },
    "axialCoord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["q", "r"],
      "properties": {
        "q": { "type": "integer" },
        "r": { "type": "integer" }
      }
    },
    "localizedText": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "language"],
      "properties": {
        "text": { "type": "string" },
        "language": { "$ref": "#/$defs/language" }
      }
    }
  }
}
