# --- Privacy: never commit real player data or generated content ---
# Live profiles live under server/data/ (ignored). The privacy guard in
# tests/validate_repo.py is the real enforcement: it fails CI if any real
# player_profile*.json (other than *.schema.json) or any non-generic profile
# fixture is committed. Do NOT add a broad player_profile*.json ignore here —
# it would also hide shared/schemas/player_profile.schema.json.
content-store/
server/data/
*.local.json

# --- Node / frontend ---
node_modules/
dist/
build/
*.tsbuildinfo
.vite/
coverage/
.nyc_output/
.eslintcache

# --- Python ---
__pycache__/
*.py[cod]
.venv/
.uv/
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/
*.egg-info/

# --- TTS / generated media (scratch) ---
*.wav
*.mp3
!shared/fixtures/**/*.wav

# --- Editors / OS ---
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json
*.log*

# --- Env / secrets ---
.env
.env.*
!.env.example
